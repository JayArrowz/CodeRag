# Copy this file to .env and fill in your values.
# docker compose will pick it up automatically.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the pgvector container (user: coderag, db: coderag).
POSTGRES_PASSWORD=changeme

# ── Database ──────────────────────────────────────────────────────────────────
# Provider: Postgres | Sqlite
# Default points to the postgres service defined in docker-compose.yml.
CODERAG_Database__Provider=Postgres
CODERAG_Database__ConnectionString=Host=postgres;Port=5432;Database=coderag;Username=coderag;Password=changeme

# ── Embedding ─────────────────────────────────────────────────────────────────
# Provider: Google | OpenAI | Ollama
CODERAG_Embedding__Provider=Ollama
CODERAG_Embedding__ApiKey=
CODERAG_Embedding__Model=qwen3-embedding
CODERAG_Embedding__Dimensions=4096
CODERAG_Embedding__BaseUrl=http://ollama:11434

# OpenAI/Google example:
# CODERAG_Embedding__Provider=OpenAI
# CODERAG_Embedding__ApiKey=sk-...
# CODERAG_Embedding__Model=text-embedding-3-small
# CODERAG_Embedding__Dimensions=1536

# ── Docker Compose profiles ───────────────────────────────────────────────────
# Set to "ollama" when using CODERAG_Embedding__Provider=Ollama.
# This starts the ollama and ollama-pull services.
COMPOSE_PROFILES=ollama

# ── Volumes ──────────────────────────────────────────────────────────────────
# Host directory mounted read-only at /workspace inside the container.
# Set to an absolute path if your source repos live outside this repo.
WORKSPACE_PATH=.

# Host-side path used by the watches-data
WATCHES_DATA_PATH=./watches-data

# Host-side path for Ollama model storage. Relative paths are resolved from
# the docker-compose.yml directory. Use an absolute path to point elsewhere.
OLLAMA_DATA_PATH=./ollama-data

# ── Persistence ───────────────────────────────────────────────────────────────
# Docker side watches file path. This is the path within the container where watches are stored.
CODERAG_WatchesFile=/data/watches.json
