@page "/search"
@inject IVectorStore Store
@inject CodebaseIndexer Indexer
@inject NavigationManager Nav

<PageTitle>Search</PageTitle>

<h1>Hybrid search</h1>
<p class="muted" style="margin-top:-0.5rem">
    Vector + lexical + symbol fast-path, fused with RRF, with neighborhood expansion. This is what an LLM client gets through <code>POST /api/query</code>.
</p>

<div class="form-row">
    <label>Query
        <input type="text" @bind="Query" @bind:event="oninput" style="min-width:340px"
               @onkeydown="OnKey" placeholder="e.g. authentication middleware, or FileWatcherService.AddWatch" />
    </label>
    <label>Workspace
        <select @bind="Workspace">
            <option value="">— all —</option>
            @if (_workspaces is not null)
            {
                @foreach (var w in _workspaces)
                {
                    <option value="@w.Workspace">@w.Workspace</option>
                }
            }
        </select>
    </label>
    <label>Top K
        <input type="text" @bind="TopK" style="min-width:60px" />
    </label>
    <label>Language
        <input type="text" @bind="Language" placeholder="csharp" />
    </label>
    <label>Kind
        <input type="text" @bind="Kind" placeholder="method_declaration" />
    </label>
    <label>Project
        <input type="text" @bind="Project" placeholder="" />
    </label>
    <button @onclick="Run" disabled="@_running">@(_running ? "Searching…" : "Search")</button>
</div>

<details style="margin-top:0.6rem">
    <summary class="muted">Advanced pipeline settings</summary>
    <div class="form-row" style="margin-top:0.4rem">
        <label><input type="checkbox" @bind="EnableSymbolMatch" /> symbol fast-path</label>
        <label><input type="checkbox" @bind="EnableVector" /> vector</label>
        <label><input type="checkbox" @bind="EnableLexical" /> lexical</label>
        <label><input type="checkbox" @bind="DiversifyResults" /> diversify</label>
        <label><input type="checkbox" @bind="ExpandNeighbors" /> expand neighbors</label>
        <label><input type="checkbox" @bind="IncludeContainingType" /> containing type</label>
        <label><input type="checkbox" @bind="IncludeIncomingEdges" /> incoming edges</label>
        <label><input type="checkbox" @bind="HydrateEdges" /> outgoing edges</label>
    </div>
    <div class="form-row">
        <label>Candidate× <input type="text" @bind="CandidateMultiplier" style="width:50px" /></label>
        <label>RRF k <input type="text" @bind="RrfK" style="width:50px" /></label>
        <label>Min vec score <input type="text" @bind="MinVectorScore" style="width:60px" /></label>
        <label>Max/file <input type="text" @bind="MaxPerFile" style="width:50px" /></label>
        <label>Max/class <input type="text" @bind="MaxPerClass" style="width:50px" /></label>
        <label>Token budget <input type="text" @bind="TokenBudget" style="width:60px" /></label>
    </div>
    <div class="form-row">
        <label>Exclude paths (comma-sep)
            <input type="text" @bind="ExcludePaths" style="min-width:260px" placeholder="tests/, examples/" />
        </label>
        <label>Embedding query override
            <input type="text" @bind="EmbedOverride" style="min-width:260px" placeholder="(optional) rewritten query for the embedder" />
        </label>
    </div>
</details>

@if (_error is not null)
{
    <div class="card" style="color:var(--bad)">@_error</div>
}

@if (_results is not null)
{
    <p class="muted">@_results.Count result(s)</p>
    @foreach (var r in _results)
    {
        var c = r.Chunk;
        <div class="card">
            <div style="display:flex;justify-content:space-between;gap:1rem">
                <div>
                    <a class="mono" style="font-weight:600;text-decoration:none"
                       href="explore/@Uri.EscapeDataString(c.Workspace)?chunk=@c.Id">
                        @(c.Signature ?? c.FunctionName)
                    </a>
                    <div class="muted mono" style="font-size:0.8rem">
                        @c.FilePath:@c.LineNumber
                        — <span class="badge info">@c.Kind</span>
                        <span class="badge">@c.Language</span>
                        <span class="badge">ws: @c.Workspace</span>
                        @if (!string.IsNullOrEmpty(c.ProjectName)) { <span class="badge">@c.ProjectName</span> }
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.2rem;align-items:flex-end">
                    <div class="badge ok">score @r.Score.ToString("0.000")</div>
                    @if (r.SourceScores is not null)
                    {
                        <div style="display:flex;gap:0.3rem;flex-wrap:wrap;justify-content:flex-end">
                            @foreach (var kv in r.SourceScores)
                            {
                                <span class="badge mono" title="@kv.Key score">@kv.Key:@kv.Value.ToString("0.00")</span>
                            }
                        </div>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(c.Documentation))
            {
                <div class="muted" style="margin-top:0.4rem">@c.Documentation</div>
            }
            @if (c.Attributes.Count > 0)
            {
                <div style="margin-top:0.4rem;display:flex;gap:0.3rem;flex-wrap:wrap;align-items:center">
                    <span class="muted" style="flex-shrink:0;font-size:0.8rem">Attributes</span>
                    @foreach (var attr in c.Attributes)
                    {
                        <span class="badge mono">[@attr]</span>
                    }
                </div>
            }
            @if (r.RelatedChunks is { Count: > 0 })
            {
                <div style="margin-top:0.4rem">
                    <span class="muted" style="font-size:0.8rem">Related</span>
                    @foreach (var rc in r.RelatedChunks)
                    {
                        <div class="mono" style="font-size:0.8rem;margin-left:0.6rem">
                            <span class="badge">@rc.Relation</span>
                            <a href="explore/@Uri.EscapeDataString(rc.Chunk.Workspace)?chunk=@rc.Chunk.Id"
                               style="text-decoration:none">
                                @(rc.Chunk.Signature ?? rc.Chunk.FunctionName)
                            </a>
                            <span class="muted">— @rc.Chunk.FilePath:@rc.Chunk.LineNumber</span>
                        </div>
                    }
                </div>
            }
            @if (r.IncomingEdges is { Count: > 0 })
            {
                <details style="margin-top:0.4rem">
                    <summary class="muted">@r.IncomingEdges.Count caller(s)</summary>
                    @foreach (var e in r.IncomingEdges)
                    {
                        <div class="mono" style="font-size:0.8rem;margin-left:0.6rem">
                            @if (e.SourceChunkId != Guid.Empty)
                            {
                                <a href="explore/@Uri.EscapeDataString(c.Workspace)?chunk=@e.SourceChunkId"
                                   style="text-decoration:none">@(e.SourceSignature ?? "?")</a>
                            }
                            else
                            {
                                @(e.SourceSignature ?? "?")
                            }
                            <span class="muted">— @e.FilePath:@e.LineNumber</span>
                        </div>
                    }
                </details>
            }
            @if (r.OutgoingEdges is { Count: > 0 })
            {
                <details style="margin-top:0.4rem">
                    <summary class="muted">@r.OutgoingEdges.Count outgoing call(s)</summary>
                    @foreach (var e in r.OutgoingEdges)
                    {
                        <div class="mono" style="font-size:0.8rem;margin-left:0.6rem">
                            @if (!e.IsExternal && e.TargetChunkId.HasValue)
                            {
                                <a href="explore/@Uri.EscapeDataString(c.Workspace)?chunk=@e.TargetChunkId"
                                   style="text-decoration:none">@(e.TargetSignature ?? e.TargetMemberName)</a>
                            }
                            else
                            {
                                @(e.TargetSignature ?? e.TargetMemberName)
                            }
                            <span class="muted">— @(e.IsExternal ? "external" : "internal") @e.EdgeKind</span>
                        </div>
                    }
                </details>
            }
            @if (!string.IsNullOrEmpty(c.Body))
            {
                <details style="margin-top:0.4rem">
                    <summary class="muted">Body</summary>
                    <pre class="code">@c.Body</pre>
                </details>
            }
            <details style="margin-top:0.4rem">
                <summary class="muted">LLM retrieval text (token budget: @TokenBudget)</summary>
                <pre class="code">@r.ToRetrievalText(null, ParseInt(TokenBudget, 800))</pre>
            </details>
        </div>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "ws")] public string? WsParam { get; set; }

    string Query { get; set; } = "";
    string Workspace { get; set; } = "";
    string TopK { get; set; } = "10";
    string Language { get; set; } = "";
    string Kind { get; set; } = "";
    string Project { get; set; } = "";

    // Advanced
    bool EnableSymbolMatch { get; set; } = true;
    bool EnableVector { get; set; } = true;
    bool EnableLexical { get; set; } = true;
    bool DiversifyResults { get; set; } = true;
    bool ExpandNeighbors { get; set; } = true;
    bool IncludeContainingType { get; set; } = true;
    bool IncludeIncomingEdges { get; set; } = true;
    bool HydrateEdges { get; set; } = true;
    string CandidateMultiplier { get; set; } = "4";
    string RrfK { get; set; } = "60";
    string MinVectorScore { get; set; } = "0.30";
    string MaxPerFile { get; set; } = "2";
    string MaxPerClass { get; set; } = "3";
    string TokenBudget { get; set; } = "800";
    string ExcludePaths { get; set; } = "";
    string EmbedOverride { get; set; } = "";

    List<WorkspaceInfo>? _workspaces;
    List<SearchResult>? _results;
    bool _running;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        _workspaces = await Store.ListWorkspacesAsync();
        if (!string.IsNullOrEmpty(WsParam)) Workspace = WsParam!;
    }

    async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Run();
    }

    static int ParseInt(string s, int fallback) => int.TryParse(s, out var v) && v > 0 ? v : fallback;
    static double ParseDouble(string s, double fallback) =>
        double.TryParse(s, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : fallback;

    async Task Run()
    {
        if (string.IsNullOrWhiteSpace(Query)) return;
        _running = true; _error = null;
        try
        {
            var filter = new SearchFilter
            {
                Workspace = string.IsNullOrWhiteSpace(Workspace) ? null : Workspace,
                Language  = string.IsNullOrWhiteSpace(Language)  ? null : Language,
                Kind      = string.IsNullOrWhiteSpace(Kind)      ? null : Kind,
                ProjectName = string.IsNullOrWhiteSpace(Project) ? null : Project,
                ExcludeFilePathContains = string.IsNullOrWhiteSpace(ExcludePaths)
                    ? new()
                    : ExcludePaths.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList(),
            };

            var opts = new QueryOptions
            {
                TopK = ParseInt(TopK, 10),
                Filter = filter,
                CandidateMultiplier = ParseInt(CandidateMultiplier, 4),
                EnableSymbolMatch = EnableSymbolMatch,
                EnableVector = EnableVector,
                EnableLexical = EnableLexical,
                RrfK = ParseInt(RrfK, 60),
                MinVectorScore = ParseDouble(MinVectorScore, 0.30),
                DiversifyResults = DiversifyResults,
                MaxPerFile = ParseInt(MaxPerFile, 2),
                MaxPerClass = ParseInt(MaxPerClass, 3),
                ExpandNeighbors = ExpandNeighbors,
                IncludeContainingType = IncludeContainingType,
                IncludeIncomingEdges = IncludeIncomingEdges,
                HydrateOutgoingEdges = HydrateEdges,
                TokenBudgetPerResult = ParseInt(TokenBudget, 800),
                EmbeddingQueryOverride = string.IsNullOrWhiteSpace(EmbedOverride) ? null : EmbedOverride,
            };

            _results = await Indexer.QueryAsync(Query, opts);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _running = false; }
    }
}
